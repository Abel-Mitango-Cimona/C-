@model EcommerceModa.Models.Produto
@{
    ViewData["Title"] = "Editar Produto";
}

<div class="form-page">
    <div class="form-header">
        <a href="/Produto" class="back-link">← Voltar à coleção</a>
        <h1 class="page-title">Editar<br><em style="font-family: var(--font-display); font-style: italic; color: var(--gold);">@Model.Nome</em></h1>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="DataCadastro" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Categoria" class="form-label"></label>
                    <select asp-for="Categoria" class="form-control">
                        <option value="">Selecione...</option>
                        @foreach (var cat in (string[])ViewBag.Categorias)
                        {
                            <option value="@cat" selected="@(Model.Categoria == cat ? "selected" : null)">@cat</option>
                        }
                    </select>
                    <span asp-validation-for="Categoria" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Preco" class="form-label"></label>
                    <input asp-for="Preco" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Preco" class="field-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Estoque" class="form-label"></label>
                    <input asp-for="Estoque" class="form-control" type="number" min="0" />
                    <span asp-validation-for="Estoque" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Cor" class="form-label"></label>
                    <input asp-for="Cor" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Tamanhos" class="form-label"></label>
                <input asp-for="Tamanhos" class="form-control" />
                <small style="color: var(--warm-gray); font-size: 11px;">Separe os tamanhos por vírgula.</small>
            </div>

            <div class="form-group">
                <label asp-for="Descricao" class="form-label"></label>
                <textarea asp-for="Descricao" class="form-control"></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a href="/Produto/Details/@Model.Id" class="btn btn-outline">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
